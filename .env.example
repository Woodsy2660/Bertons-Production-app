# Database (local Docker)
DATABASE_URL=postgresql+asyncpg://berton:berton_dev@localhost:5433/berton_bottling

# Database (Vercel production — use Neon, Supabase, or Vercel Postgres)
# DATABASE_URL=postgresql+asyncpg://user:pass@host.neon.tech/berton_bottling?ssl=require

# App
DEBUG=true
SECRET_KEY=change-this-in-production

# File storage (local)
UPLOAD_DIR=./uploads
COMPILED_OUTPUT_DIR=./compiled_output
STORAGE_BACKEND=local

# File storage (Vercel — create a Blob store and connect it to the project)
# STORAGE_BACKEND=blob
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# BLOB_STORE_ID=store_...   # set automatically when Blob store is connected
# BLOB_ACCESS=private

# Shared logins (two roles only — not per-person accounts)
MANAGER_USERNAME=manager
MANAGER_PASSWORD=manager
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=operator

# Operator run list: today's runs + recently completed
OPERATOR_COMPLETED_RUN_DAYS=7
OPERATOR_COMPLETED_RUN_LIMIT=10